<mjml>
    <mj-head>
        <mj-attributes>
            <mj-text font-family="Arial, Helvetica, sans-serif" font-size="14px" />
        </mj-attributes>
    </mj-head>

    <mj-body background-color="#f4f6f8" width="800px">

        <!-- Header -->
        <mj-section background-color="#1e293b" padding="16px">
            <mj-column>
                <mj-text color="#ffffff" font-size="18px" font-weight="bold">
                    Pending Form Notification
                </mj-text>
            </mj-column>
        </mj-section>

        <!-- Content Card -->
        <mj-section padding="0">
            <mj-column background-color="#ffffff" padding="20px" border-radius="6px">
                <mj-text>
                    Dear xxxxx,
                </mj-text>

                <mj-text color="#555">
                    This is to inform you that there are pending forms that have not been processed or responded to
                    within the specified period (2–3 weeks).
                    Please review the pending items listed below and follow up with the responsible users accordingly.
                </mj-text>

                <!-- Table -->
                <mj-table width="100%" table-layout="fixed">

                    <tr style="background:#e5e7eb; font-weight:bold;">
                        <th width="12%" style="padding:8px;">Form No.</th>
                        <th width="10%" style="padding:8px;">Pending Duration</th>
                        <th width="20%" style="padding:8px;">Link</th>
                    </tr>


                    <tr style="border-bottom:1px solid #eee;">
                        <td style="padding:8px;">Alabaka</td>
                        <td style="padding:8px;">melomelo weeks</td>
                        <td style="padding:8px; text-align:center;">
                            <a href="#">
                                View Form
                            </a>
                        </td>
                    </tr>


                </mj-table>

            </mj-column>
        </mj-section>

        <!-- Footer -->
        <mj-section background-color="#f1f5f9" padding="10px">
            <mj-column>
                <mj-text font-size="12px" color="#888" align="center">
                    This is an automated email. Please do not reply.
                </mj-text>
            </mj-column>
        </mj-section>

    </mj-body>
</mjml>