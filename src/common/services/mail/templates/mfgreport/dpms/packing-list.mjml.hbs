<mjml>
    <mj-head>
        <mj-attributes>
            <mj-text font-family="Arial, Helvetica, sans-serif" font-size="14px" />
        </mj-attributes>
        <mj-style inline="inline">
            th, td {
                vertical-align: top;
            }
        </mj-style>
    </mj-head>

    <mj-body background-color="#f4f6f8" width="800px">

        <!-- Header -->
        <mj-section background-color="#1e293b" padding="16px">
            <mj-column>
                <mj-text color="#ffffff" font-size="18px" font-weight="bold">
                    Packing List Issued Notification
                </mj-text>
            </mj-column>
        </mj-section>

        <!-- Content Card -->
        <mj-section padding="0">
            <mj-column background-color="#ffffff" padding="20px" border-radius="6px">

                <mj-text>
                    Dear {{name}},
                </mj-text>

                <mj-text color="#555">
                    Please be informed that the packing list has been issued successfully.
                    <a href="{{path}}" style="color:#1e293b; text-decoration:none;">Click here</a> to view the details.
                </mj-text>

                <!-- Table -->
                <mj-table width="100%" table-layout="fixed">

                    <tr style="background:#e5e7eb; font-weight:bold;">
                        <th width="10%" style="padding:8px; white-space:nowrap;">ISSUE TYPE</th>
                        <th width="10%" style="padding:8px; white-space:nowrap;">SHOP ORDER NO</th>
                        <th width="20%" style="padding:8px; white-space:nowrap;">SUBJECT</th>
                        <th width="30%" style="padding:8px;">NAME OF BLDG</th>
                        <th width="30%" style="padding:8px;">SOLD TO</th>
                    </tr>
                    <tr style="border-bottom:1px solid #eee;">
                        <td style="padding:8px; white-space:nowrap; ali">{{issueType}}</td>
                        <td style="padding:8px; ">{{shopOrderNo}}</td>
                        <td style="padding:8px; white-space:nowrap;">{{subject}}</td>
                        <td style="padding:8px;">{{nameOfBldg}}</td>
                        <td style="padding:8px;">{{soldTo}}</td>
                    </tr>
                </mj-table>

            </mj-column>
        </mj-section>

        <!-- Footer -->
        <mj-section background-color="#f1f5f9" padding="10px">
            <mj-column>
                <mj-text font-size="12px" color="#888" align="center">
                    This is an automated email. Please do not reply.
                </mj-text>
            </mj-column>
        </mj-section>

    </mj-body>
</mjml>